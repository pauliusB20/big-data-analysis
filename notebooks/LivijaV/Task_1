# problem here is that the MMSI can end up in different chunks
# harder to detect anomalies if same ships are processesed by different workers


from multiprocessing import Process, Queue
import csv
from datetime import datetime
from collections import defaultdict

files = ["Data/aisdk-2025-02-28.csv", "Data/aisdk-2025-03-01.csv"]

def is_invalid_mmsi(mmsi):
    return mmsi in {"000000000", "111111111", "123456789", "222222222", "333333333", "444444444", "555555555", "666666666", "777777777",
                "888888888", "999999999", "987654321"} or not mmsi.isdigit() or len(mmsi) != 9

# Streaming generator
def stream_valid_rows(files):
    for filename in files:
        with open(filename, "r", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            for row in reader:
                if is_invalid_mmsi(row["MMSI"]):
                    continue
                yield {
                    "mmsi": row["MMSI"],
                    "timestamp": row["# Timestamp"],
                    "lat": float(row["Latitude"]),
                    "lon": float(row["Longitude"]),
                    "sog": float(row["SOG"]) if row["SOG"] else None,
                    "draught": float(row["Draught"]) if row["Draught"] else None
                    }

# Chunk generator
def chunk_rows(files, chunk_size=50000):
    chunk = [] #empty list to store rows until chunk_size is reached
    for row in stream_valid_rows(files):
        chunk.append(row)
        if len(chunk) >= chunk_size:
            yield chunk #function is paused and chuck is returned to teh caller 
            chunk = [] #new empty list for the next chunk
    if chunk:  # for left-over rows after for loop finishes
        yield chunk

# Producer putting the chunks into a queue for workers
def producer(q, files):
    for i, chunk in enumerate(chunk_rows(files)): #drop i and enumerate for real version
        q.put(chunk) #chunks are generated one at the time and put into queue
        print(f"Producer sent chunk {i+1}")  #monitoring - test
