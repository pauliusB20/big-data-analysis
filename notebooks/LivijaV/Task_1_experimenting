# Experimenting with groupping rows by MMSI and sending to workers (with hash)


from multiprocessing import Process, Queue
import csv
from datetime import datetime
from collections import defaultdict

files = ["Data/aisdk-2025-02-28.csv", "Data/aisdk-2025-03-01.csv"]

def is_invalid_mmsi(mmsi):
    return mmsi in {"000000000", "111111111", "123456789", "222222222", "333333333", "444444444", "555555555", "666666666", "777777777",
                "888888888", "999999999", "987654321"} or not mmsi.isdigit() or len(mmsi) != 9

# Streaming generator
def stream_valid_rows(files):
    for filename in files:
        with open(filename, "r", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            for row in reader:
                if is_invalid_mmsi(row["MMSI"]):
                    continue
                yield {
                    "mmsi": row["MMSI"],
                    "timestamp": row["# Timestamp"],
                    "lat": float(row["Latitude"]),
                    "lon": float(row["Longitude"]),
                    "sog": float(row["SOG"]) if row["SOG"] else None,
                    "draught": float(row["Draught"]) if row["Draught"] else None
                    } #only "relevant" columns (to be defined later)

# Groupping rows by MMSI and assigning to workers, one queue per worker
def produce_chunks(qs, files, chunk_size=10000):
    temp_chunk = [[] for _ in range(len(qs))] #to store rows until chunk_size is reached
    
    for row in stream_valid_rows(files):
        worker_id = hash(row["mmsi"]) % len(qs) #assign worker id based on mmsi
        temp_chunk[worker_id].append(row)

        if len(temp_chunk[worker_id]) >= chunk_size:
            qs[worker_id].put(temp_chunk[worker_id]) #put the chunk into the queue for the worker
            temp_chunk[worker_id] = [] #reset the chunk for the worker

    # Remaining rows
    for worker_id, temp in enumerate(temp_chunk):
        if temp:
            qs[worker_id].put(temp) #put the remaining rows into the queue for the

    # Telling workers to stop once all chunks are done
    for q in qs:
        q.put(None)

# Worker processing chunks from the queue
def worker(q, worker_id):
    all_mmsi = defaultdict(list) #store data grouped mmsi
    while True:
        chunk = q.get()
        if chunk is None:  #break teh process
            break
        # MAIN CODE HERE
        for row in chunk:
            all_mmsi[row["mmsi"]].append(row["timestamp"])
    # Monitoring:
    print(f"Worker {worker_id} collected {len(all_mmsi)} MMSIs", flush=True)

if __name__ == "__main__": #need this for multiprocessing to work properly on Windows?
    worker_no = 4 #up to 5
    qs = [Queue(maxsize=10) for _ in range(worker_no)]  #at most 10 chunks are stored in emmory at the time
    start_time = datetime.now()

    # Start workers
    workers = [] #empty list for workers, needed to append them later
    for i in range(worker_no): #creating each worker
        p = Process(target=worker, args=(qs[i], i)) #each worker runs the worker function, queue and id as arguments
        p.start() #workers start running, pulling the chunks from the queue 
        workers.append(p) #stores process object

    # Start producing chunks for queue
    produce_chunks(qs, files) 

    # Wait for workers to finish
    for w in workers:
        w.join()

    end_time = datetime.now()
    overall_time = (end_time - start_time).seconds
    print(f"Run time: {overall_time} seconds")
